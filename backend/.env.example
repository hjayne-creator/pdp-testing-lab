OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=

DATABASE_URL=sqlite:///./lab.db
APP_HOST=0.0.0.0
APP_PORT=8001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AUTH_USERNAME=admin
AUTH_PASSWORD=
AUTH_SESSION_SECRET=
# Production (separate frontend/API hosts): AUTH_COOKIE_SECURE=true, AUTH_COOKIE_SAMESITE=none

SERPAPI_COST_USD=0.01
FIRECRAWL_COST_USD=0.01
FIRECRAWL_TIMEOUT_MS=120000
FIRECRAWL_PDF_TIMEOUT_MS=300000
FIRECRAWL_PDF_RETRY_TIMEOUT_MS=600000
MAX_RUN_SECONDS=180

# Run history retention (SQLite lab.db; use a Railway volume for persistence)
RUN_HISTORY_MAX_COUNT=100
RUN_HISTORY_MAX_AGE_DAYS=30

# Research token guardrails (0 = disable PDF byte-size precheck)
RESEARCH_PDF_MAX_BYTES=2000000
RESEARCH_PDF_MAX_CHARS=25000
RESEARCH_PAGE_MAX_CHARS=50000
RESEARCH_EVIDENCE_MAX_CHARS=12000
